RewriteEngine On
DirectoryIndex index.php index.html
RewriteRule ^index\.html$ /index.php?lang=en [R=301,L]
RewriteRule ^index_es\.html$ /index.php?lang=es [R=301,L]
RewriteCond %{HTTP_HOST} ^www\.trustedpanamastays\.com$ [NC]
RewriteRule ^(.*)$ https://trustedpanamastays.com/$1 [L,R=301]


PassengerAppRoot /home/u945180857/domains/trustedpanamastays.com/nodejs
PassengerAppType node
PassengerNodejs /opt/alt/alt-nodejs22/root/bin/node
PassengerStartupFile server.js
PassengerBaseURI /
PassengerRestartDir /home/u945180857/domains/trustedpanamastays.com/nodejs/tmp
SetEnv NODE_OPTIONS "--require /home/u945180857/domains/trustedpanamastays.com/public_html/.builds/config/preload-timestamp.js"
SetEnv LSNODE_CONSOLE_LOG console.log
RewriteRule ^\.builds - [F,L]
